# EmailJS Configuration Keys
# Obtain these values from https://dashboard.emailjs.com/

# 1. Email Service ID (from "Email Services" tab)
VITE_EMAILJS_SERVICE_ID=service_placeholder

# 2. Email Template ID (from "Email Templates" tab)
VITE_EMAILJS_TEMPLATE_ID=template_placeholder

# 3. Public Key (from "Account" -> "API Keys" tab)
VITE_EMAILJS_PUBLIC_KEY=public_placeholder
